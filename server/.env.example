# Supabase (service role — NUNCA commitar o .env real)
SUPABASE_URL=https://ewerfpxniciegagnretb.supabase.co
SUPABASE_SERVICE_KEY=coloque-a-service_role-key-aqui

# Servidor
PORT=8787
APP_URL=http://localhost:8080
SCHEDULER_CRON=*/1 * * * *

# Publicação: mock=true marca como publicado sem chamar a Meta (Fase 1)
PUBLISH_MOCK=true

# Instagram Business Login (preencher na Fase/Epic D)
# IG_APP_ID/SECRET = "Instagram app ID" e "Instagram app secret" (produto Instagram do app Meta)
IG_APP_ID=
IG_APP_SECRET=
IG_OAUTH_REDIRECT=http://localhost:8787/oauth/instagram/callback
